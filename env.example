# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Server-side / scripts only (npm run seed:catalog, seed:medical). Never ship in the app.
# Dashboard: Project Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Also in Supabase Dashboard: Authentication → Providers → Google (enable + OAuth client from Google Cloud).
# Authentication → URL Configuration: allow smartnutrition://auth/callback (matches app.json scheme + lib/oauth.ts).

# Firebase
EXPO_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
EXPO_PUBLIC_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID

# Google Sign-In (Web Client ID from Google Cloud Console)
# Path: console.cloud.google.com -> APIs & Services -> Credentials -> OAuth 2.0 Client IDs -> Web client
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com

# FCM / push (server only): configure in Supabase Dashboard → Edge Functions → your function → Secrets.
# Do NOT add FCM_PROJECT_ID, service account email, or private key to this file or to the Expo app .env.