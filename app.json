{
  "expo": {
    "name": "Smart Nutrition",
    "slug": "smart-nutrition",
    "owner": "solyso",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "smartnutrition",
    "splash": {
      "backgroundColor": "#080808"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#080808"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "@react-native-firebase/messaging"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
